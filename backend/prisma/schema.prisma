// Prisma şema dosyası
// Referans: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOT: Tablolar (users, message_threads, messages, pool_entries) bu dosyaya
// Görev 2.3 - 2.6'da sırayla eklenecek. Bu adımda (Görev 2.2) sadece
// Prisma'nın kurulumu ve veritabanına bağlanabildiği doğrulanıyor.

// --------------------------------------------------------
// GÖREV 2.3 — users tablosu
// --------------------------------------------------------

enum UserStatus {
  active
  suspended
  deleted
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  // Telefon numarası ASLA düz metin saklanmaz, sadece hash (Bölüm 10).
  phoneNumberHash String     @unique @map("phone_number_hash")
  // Kullanici istegi: hukuki bir talep/soruşturma geldiginde "bu hesap
  // kime ait" sorusuna cevap verebilmek icin - hash'ten farkli olarak
  // AES ile SIFRELI ama GERI DONDURULEBILIR sekilde saklanir. Normal
  // uygulama akislarinda hicbir zaman kullanilmaz/donulmez, sadece
  // yonetim ekranindan, bilincli bir "ac" islemiyle cozulebilir.
  phoneNumberEncrypted String? @map("phone_number_encrypted")
  displayName     String?    @map("display_name")
  // Kullanici istegi: girisin bir parcasi olarak secilen 10 hazir
  // avatardan biri - hicbir gercek kimlik bilgisi tasimaz, sadece
  // gorsel bir tercih (Bolum 8 gizlilik modeline aykiri degil).
  avatarId String? @map("avatar_id") // bkz. frontend AVATARS listesi
  createdAt       DateTime   @default(now()) @map("created_at")
  lastSeenAt      DateTime?  @map("last_seen_at")
  status          UserStatus @default(active)

  initiatedThreads MessageThread[] @relation("ThreadInitiator")
  receivedThreads  MessageThread[] @relation("ThreadRecipient")
  sentMessages     Message[]
  poolEntries      PoolEntry[]
  poolAttempts     PoolAttempt[]
  blockedUsers     Block[]         @relation("Blocker")
  blockedByUsers   Block[]         @relation("Blocked")
  reports          Report[]
  threadUnlocks    ThreadUnlock[]

  @@map("users")
}

// --------------------------------------------------------
// GÖREV 2.4 — message_threads tablosu
// --------------------------------------------------------

enum ThreadOriginType {
  direct
  pool
}

enum ThreadLockType {
  password
  question
  none
}

model MessageThread {
  id              String           @id @default(uuid()) @db.Uuid
  originType      ThreadOriginType @map("origin_type")

  initiatorUserId String  @map("initiator_user_id") @db.Uuid
  initiator       User    @relation("ThreadInitiator", fields: [initiatorUserId], references: [id])

  // Pool senaryosunda eşleşme olana kadar null (Bölüm 4, 8).
  recipientUserId String? @map("recipient_user_id") @db.Uuid
  recipient       User?   @relation("ThreadRecipient", fields: [recipientUserId], references: [id])

  lockType     ThreadLockType @map("lock_type")
  // Parola/cevap ASLA düz metin saklanmaz, sadece hash (Bölüm 8, 10).
  lockSecretHash String?      @map("lock_secret_hash")
  questionText   String?      @map("question_text")

  // Kullanici geri bildirimi: mesajı gönderen kişi, kendi "Mesajlarım"
  // listesinde kime gönderdiğini görebilsin. Bu, genel "numara asla
  // düz metin saklanmaz" kuralına ("Bölüm 8, 10") bilinçli, dar
  // kapsamlı bir istisna - sadece göndericinin KENDİ YAZDIĞI numarayı,
  // SADECE KENDİSİNE (initiator'a) geri gösteriyoruz. Alıcıya veya
  // başka hiç kimseye asla döndürülmez (bkz. listMyThreads).
  recipientPhoneDisplay String? @map("recipient_phone_display")

  // Kullanici istegi: opsiyonel ek bildirim kanali - alici HALA
  // telefon/OTP ile giris yapmak zorunda (bu, giris/kimlik sistemini
  // degistirmez), ama gonderen isterse ek olarak bir e-posta adresine
  // de bildirim gonderilsin diye bu alani doldurabilir.
  recipientNotificationEmail String? @map("recipient_notification_email")

  // Kullanici geri bildirimi: "mesaj silme" ozelligi - gercekte veriyi
  // silmiyoruz (karsi tarafin gorunumunu etkilememeli), sadece
  // kullanicinin KENDI "Mesajlarim" listesinden gizliyoruz.
  hiddenByInitiator Boolean @default(false) @map("hidden_by_initiator")
  hiddenByRecipient Boolean @default(false) @map("hidden_by_recipient")

  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  messages Message[]
  reports  Report[]
  unlocks  ThreadUnlock[]

  @@map("message_threads")
}

// --------------------------------------------------------
// GÖREV 2.5 — messages tablosu
// --------------------------------------------------------

model Message {
  id       String        @id @default(uuid()) @db.Uuid
  threadId String        @map("thread_id") @db.Uuid
  thread   MessageThread @relation(fields: [threadId], references: [id])

  senderUserId String? @map("sender_user_id") @db.Uuid
  sender       User?   @relation(fields: [senderUserId], references: [id])

  body String

  // Kullanici istegi: sikayet sonuclandirildiginde, admin'in girdigi
  // aciklama, sikayeti yapan kisiye "YouHaveMi"den gelen bir sistem
  // mesaji olarak ilgili thread'de gorunur. Bu tur mesajlarda
  // senderUserId null'dur (gercek bir kullanici degil).
  isSystemMessage Boolean @default(false) @map("is_system_message")

  // true ise API response'unda sender_user_id backend seviyesinde
  // alan filtrelemesiyle hiç dönmez (Bölüm 8, Anonimlik Modeli).
  isAnonymous       Boolean   @default(false) @map("is_anonymous")
  readAt            DateTime? @map("read_at")
  destroyAfterRead  Boolean   @default(false) @map("destroy_after_read")
  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([threadId])
  @@map("messages")
}

// --------------------------------------------------------
// GÖREV 2.6 — pool_entries tablosu
// --------------------------------------------------------

enum PoolVisibility {
  public
  unlisted
}

enum PoolMatchMode {
  exact
  review
}

enum PoolAttemptStatus {
  pending
  accepted
  rejected
}

// Kullanici istegi: "Tum Yanitlari Goster" modundaki sorularda, her
// yanit (dogru/yanlis fark etmeksizin) burada BEKLEMEDE olarak
// kaydedilir. Soru sahibi kabul ederse bir MessageThread olusur,
// reddederse hicbir sey olmaz. Farkli kisiler ayni soruya yanit
// verirse, her biri icin AYRI bir kayit (ve kabul edilirse ayri bir
// thread) olusur.
model PoolAttempt {
  id String @id @default(uuid()) @db.Uuid

  poolEntryId String    @map("pool_entry_id") @db.Uuid
  poolEntry   PoolEntry @relation(fields: [poolEntryId], references: [id])

  attempterUserId String @map("attempter_user_id") @db.Uuid
  attempter       User   @relation(fields: [attempterUserId], references: [id])

  // NOT: bu mod icin cevap BILEREK duz metin saklanir - soru sahibinin
  // yaniti okuyup "kabul/reddet" karari verebilmesi gerekiyor (exact
  // modundaki hash'leme burada gecerli degil).
  answerText String @map("answer_text")

  status PoolAttemptStatus @default(pending)
  // Kabul edildiyse, olusturulan thread'in ID'si (referans/izlenebilirlik icin).
  threadId String? @map("thread_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")

  @@index([poolEntryId])
  @@index([attempterUserId])
  @@index([status])
  @@map("pool_attempts")
}

model PoolEntry {
  id      String @id @default(uuid()) @db.Uuid

  ownerUserId String @map("owner_user_id") @db.Uuid
  owner       User   @relation(fields: [ownerUserId], references: [id])

  title        String
  questionText String @map("question_text")
  // Cevap ASLA düz metin saklanmaz, sadece hash (Bölüm 8, 10).
  answerHash   String @map("answer_hash")

  category   String?        @map("category")
  visibility PoolVisibility @default(public)

  // Kullanici istegi: "Kesin Eslessin" (varsayilan - dogru cevap
  // otomatik eslestirir) vs "Tum Yanitlari Goster" (herhangi bir
  // yanit, dogru/yanlis fark etmeksizin, soru sahibine INCELEME icin
  // dusar - sahip kabul/reddeder, kabul edilirse ayri bir mesaj
  // kutusu acilir).
  matchMode PoolMatchMode @default(exact) @map("match_mode")

  // Rate-limit/brute-force takibi için (Bölüm 10).
  attemptCount Int @default(0) @map("attempt_count")

  // Kullanici istegi: soru sahibi istedigi zaman kaldirabilir - kendi
  // kendine kalkmaz, sadece bilincli bir "sil" islemiyle gizlenir.
  hiddenByOwner Boolean @default(false) @map("hidden_by_owner")

  attempts PoolAttempt[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("pool_entries")
}

// --------------------------------------------------------
// GÖREV 7.2 — blocks tablosu (engelleme)
// --------------------------------------------------------

model Block {
  id String @id @default(uuid()) @db.Uuid

  blockerUserId String @map("blocker_user_id") @db.Uuid
  blocker       User   @relation("Blocker", fields: [blockerUserId], references: [id])

  blockedUserId String @map("blocked_user_id") @db.Uuid
  blocked       User   @relation("Blocked", fields: [blockedUserId], references: [id])

  createdAt DateTime @default(now()) @map("created_at")

  // Ayni kisi ayni numarayi birden fazla kez engelleyemez.
  @@unique([blockerUserId, blockedUserId])
  @@map("blocks")
}

// --------------------------------------------------------
// GÖREV 7.3 — reports tablosu (şikayet / moderasyon kuyruğu)
// --------------------------------------------------------

enum ReportStatus {
  pending
  reviewed
  dismissed
}

model Report {
  id String @id @default(uuid()) @db.Uuid

  reporterUserId String @map("reporter_user_id") @db.Uuid
  reporter       User   @relation(fields: [reporterUserId], references: [id])

  threadId String        @map("thread_id") @db.Uuid
  thread   MessageThread @relation(fields: [threadId], references: [id])

  reason String?
  status ReportStatus @default(pending)

  // Kullanici istegi: sikayet sonuclandirildiginde admin'in girdigi
  // aciklama - sikayeti yapan kisiye sistem mesaji olarak gonderilir.
  resolutionNote String? @map("resolution_note")

  createdAt DateTime @default(now()) @map("created_at")

  @@map("reports")
}

// --------------------------------------------------------
// Yonetim ekrani icin ayarlanabilir parametreler (Bolum 10'un
// devami - test surecinde rate limit gibi degerlerin deploy
// gerekmeden degistirilebilmesi icin).
// --------------------------------------------------------

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// --------------------------------------------------------
// Kullanici geri bildirimi: bir kullanici bir thread'in parolasini/
// cevabini bir kez dogru girdiginde, bir daha (cikis yapsa/tarayici
// kapatsa bile) tekrar sorulmamali. Bu tablo "kim, hangi thread'i
// dogru bilgiyle actı" kaydini kalici olarak tutar.
// --------------------------------------------------------

model ThreadUnlock {
  id String @id @default(uuid()) @db.Uuid

  threadId String        @map("thread_id") @db.Uuid
  thread   MessageThread @relation(fields: [threadId], references: [id])

  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  unlockedAt DateTime @default(now()) @map("unlocked_at")

  // Ayni kullanici ayni thread icin bir kez kaydedilir.
  @@unique([threadId, userId])
  @@map("thread_unlocks")
}

// --------------------------------------------------------
// Yonetim ekrani - proje/gorev takibi (kullanici istegi).
// --------------------------------------------------------

enum AdminTaskStatus {
  pending
  in_progress
  completed
  cancelled
}

enum AdminTaskPriority {
  low
  medium
  high
}

model AdminTask {
  id          String            @id @default(uuid()) @db.Uuid
  title       String
  description String?
  status      AdminTaskStatus   @default(pending)
  priority    AdminTaskPriority @default(medium)
  dueDate     DateTime?         @map("due_date")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("admin_tasks")
}

// --------------------------------------------------------
// Kullanici istegi: sistem sahibi olarak hukuki bir talep/soruşturma
// durumunda ispatlayabilecek/belgeleyebilecek kayitlar. Bu tablolar
// normal uygulama akislarindan (kullanicilarin gordugu API'ler) HICBIR
// ZAMAN okunmaz - sadece yonetim ekranindan, bilinçli bir islemle
// erisilir.
// --------------------------------------------------------

// Genel islem gunlugu: OTP istekleri, giris/dogrulama, mesaj gonderme,
// thread acma, engelleme, sikayet, admin islemleri - IP ve zaman
// damgasiyla birlikte. Ekleme-sadece (append-only), hicbir zaman
// guncellenmez/silinmez.
model AuditLog {
  id String @id @default(uuid()) @db.Uuid

  eventType String @map("event_type") // orn. "otp_request", "message_sent", "thread_unlock", "block", "report"
  userId    String? @map("user_id") @db.Uuid
  threadId  String? @map("thread_id") @db.Uuid

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  // Olaya ozel ek bilgi (JSON) - orn. hangi telefon numarasina OTP
  // gonderildi, hangi kilit tipiyle thread acildi, vb.
  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([threadId])
  @@index([eventType])
  @@map("audit_logs")
}

// Her mesajin, olusturuldugu anda alinan SIFRELI bir kopyasi - normal
// "messages" tablosundaki kayit (destroy_after_read ile) silinse bile
// bu arsiv kaydi kalir. Kullanici geri bildirimi: hukuki ispat icin
// gerekli.
model MessageAudit {
  id String @id @default(uuid()) @db.Uuid

  originalMessageId String  @map("original_message_id") @db.Uuid
  threadId           String @map("thread_id") @db.Uuid

  senderUserId String? @map("sender_user_id") @db.Uuid

  // Mesaj govdesi AES ile sifreli saklanir (duz metin degil) - sadece
  // yonetim ekranindan, bilincli bir "coz" islemiyle okunabilir.
  bodyEncrypted String @map("body_encrypted")

  isAnonymous Boolean @default(false) @map("is_anonymous")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([threadId])
  @@map("message_audits")
}




