// Prisma şema dosyası
// Referans: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NOT: Tablolar (users, message_threads, messages, pool_entries) bu dosyaya
// Görev 2.3 - 2.6'da sırayla eklenecek. Bu adımda (Görev 2.2) sadece
// Prisma'nın kurulumu ve veritabanına bağlanabildiği doğrulanıyor.

// --------------------------------------------------------
// GÖREV 2.3 — users tablosu
// --------------------------------------------------------

enum UserStatus {
  active
  suspended
  deleted
}

model User {
  id              String     @id @default(uuid()) @db.Uuid
  // Telefon numarası ASLA düz metin saklanmaz, sadece hash (Bölüm 10).
  phoneNumberHash String     @unique @map("phone_number_hash")
  displayName     String?    @map("display_name")
  createdAt       DateTime   @default(now()) @map("created_at")
  lastSeenAt      DateTime?  @map("last_seen_at")
  status          UserStatus @default(active)

  @@map("users")
}

