# Prisma, komutları backend/ klasöründen çalıştırdığımız için
# DATABASE_URL değerini burada da (backend/.env) arar.
# Kök dizindeki .env.example ile aynı DATABASE_URL değerini kullan.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ozel_mesaj_dev

# Backend uygulamasi da bu klasordeki .env dosyasini okur (dotenv/config).
PORT=4000
REDIS_URL=redis://localhost:6379
PHONE_HASH_SECRET=change-me-phone-hash-secret
OTP_LENGTH=4
OTP_TTL_SECONDS=300

# İleti Merkezi SMS sağlayıcı bilgileri
SMS_PROVIDER=iletimerkezi
SMS_USERNAME=your-iletimerkezi-username
SMS_PASSWORD=your-iletimerkezi-password
# Test/deneme hesaplarinda genellikle "APITEST" onayli gelir (panelden
# kontrol et: Ayarlar -> Basliklarim). Gercek marka basligi onaylandiginda
# (Gorev 4.2) burasi guncellenecek.
SMS_SENDER_HEADER=APITEST
# true iken gercek SMS gonderilmez, kod sadece konsola loglanir.
SMS_MOCK_MODE=true

# JWT - Katman 1 (kullanici oturumu)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# JWT - Katman 2 (thread bazli yetkilendirme, Gorev 5.2)
JWT_THREAD_ACCESS_SECRET=change-me-thread-secret
JWT_THREAD_ACCESS_EXPIRES_IN=10m

# Frontend'in hangi adreste calisacagi (SMS bildirim linki icin, Gorev 5.1)
APP_BASE_URL=http://localhost:3000

# destroy_after_read mesajlarin, okunduktan kac saniye sonra silinecegi
# (Gorev 5.6). Test/demo icin kisa (10sn); production'da 0 (aninda) veya
# 86400 (24 saat) gibi degerler dusunulebilir.
MESSAGE_DESTROY_DELAY_SECONDS=10

# Genel, IP bazli rate limiting (Gorev 7.1) - tum endpoint'lere
# varsayilan olarak uygulanir.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Havuz (pool) cevap denemesi icin dakikalik rate limit (Gorev 6.4).
POOL_ATTEMPT_RATE_LIMIT_PER_MINUTE=5

# Bir kullanicinin (thread baslatan olarak) alacagi kac sikayetten
# sonra hesabinin otomatik askiya alinacagi (Gorev 7.4).
REPORT_SUSPEND_THRESHOLD=3
