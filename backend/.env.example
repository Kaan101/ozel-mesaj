# Prisma, komutları backend/ klasöründen çalıştırdığımız için
# DATABASE_URL değerini burada da (backend/.env) arar.
# Kök dizindeki .env.example ile aynı DATABASE_URL değerini kullan.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ozel_mesaj_dev

# Backend uygulamasi da bu klasordeki .env dosyasini okur (dotenv/config).
PORT=4000
REDIS_URL=redis://localhost:6379
PHONE_HASH_SECRET=change-me-phone-hash-secret
OTP_LENGTH=4
OTP_TTL_SECONDS=300
