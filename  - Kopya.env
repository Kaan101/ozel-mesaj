# ============================================
# ÖZEL MESAJ — ORTAM DEĞİŞKENLERİ ŞABLONU
# ============================================
# Bu dosya bir ŞABLONDUR. Gerçek değerlerle doldurup ".env" adıyla
# kaydet — ".env" dosyası asla git'e eklenmez (.gitignore'da tanımlı).

# --------------------------------------------
# UYGULAMA GENEL AYARLARI
# --------------------------------------------
NODE_ENV=development
PORT=4000
APP_BASE_URL=http://localhost:3000

# --------------------------------------------
# POSTGRESQL (Ana Veritabanı)
# --------------------------------------------
# Docker Compose ile lokal geliştirmede kullanılacak bağlantı bilgisi.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ozel_mesaj_dev

# --------------------------------------------
# REDIS (OTP, Rate-Limit, TTL'li Veri)
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# TELEFON HASH'LEME
# --------------------------------------------
# Telefon numaralari bu secret ile HMAC-SHA256 kullanilarak hash'lenir.
PHONE_HASH_SECRET=change-me-phone-hash-secret

# --------------------------------------------
# JWT / AUTH
# --------------------------------------------
# Bu değerleri prod'da mutlaka rastgele, uzun ve gizli tut.
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Thread bazlı yetkilendirme (Katman 2) için ayrı secret
JWT_THREAD_ACCESS_SECRET=change-me-thread-secret
JWT_THREAD_ACCESS_EXPIRES_IN=10m

# --------------------------------------------
# OTP AYARLARI
# --------------------------------------------
OTP_LENGTH=4
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_MINUTE=1
OTP_RATE_LIMIT_PER_HOUR=5

# --------------------------------------------
# SMS SAĞLAYICI (İleti Merkezi)
# --------------------------------------------
SMS_PROVIDER=iletimerkezi
# iletimerkezi.com panelinde giriş yaparken kullanılan kullanıcı adı/şifre
SMS_USERNAME=5323770376
SMS_PASSWORD=Ivergnal01.
# Panelde önceden onaylanmış başlık (sender ID)
SMS_SENDER_HEADER=APITEST

# Test/staging ortamında gerçek SMS göndermemek için:
SMS_MOCK_MODE=True

# --------------------------------------------
# GÜVENLİK / RATE LIMITING
# --------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --------------------------------------------
# HATA İZLEME (Sentry benzeri)
# --------------------------------------------
ERROR_TRACKING_DSN=

# --------------------------------------------
# FRONTEND (Next.js) İÇİN GEREKEN DEĞİŞKENLER
# --------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
