# Backend API'nin adresi (Gorev 9.4, API Client katmani).
# NEXT_PUBLIC_ oneki, bu degiskenin tarayiciya (client-side) acik
# olmasi gerektigini Next.js'e soyler.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Frontend'in kendi adresi (Gorev 14.5, SEO metadata/OG etiketleri icin).
NEXT_PUBLIC_APP_URL=http://localhost:3000
